# .claude — mostly per-user, but a few pieces ship with the repo:
# the story-loop skill, install-story-loop skill, the safety-guard +
# test-failure + session-start + notification hooks (portable, tested on
# Windows via git-bash), and two read-only env-check commands.
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/bmad-elcai-story-loop/
!.claude/skills/bmad-elcai-story-loop/**
!.claude/skills/install-story-loop/
!.claude/skills/install-story-loop/**
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/git-safety-guard.ps1
!.claude/hooks/git-safety-guard.sh
!.claude/hooks/test-failure-nudge.ps1
!.claude/hooks/test-failure-nudge.sh
!.claude/hooks/health-check-nudge.ps1
!.claude/hooks/health-check-nudge.sh
!.claude/hooks/session-start-nudge.sh
!.claude/hooks/notify.sh
!.claude/settings.json
!.claude/commands/
.claude/commands/*
!.claude/commands/elcai-check-env.md
!.claude/commands/check-training-env.md

# _bmad — installer output, per-user; nothing under _bmad ships with the repo in 6.10.x,
# except the team config override file (documented as committed in its own header).
_bmad/*
!_bmad/custom/
_bmad/custom/*
!_bmad/custom/config.toml

# .agents — BMAD's per-IDE skill output for github-copilot; per-user, not shipped
.agents/

# .github/{agents,prompts,skills} — BMAD + ELCAi's github-copilot IDE output; per-user, not shipped.
# No real CI workflows live here today; if .github/workflows/ is ever added, allowlist it explicitly.
.github/

.mcp.json

